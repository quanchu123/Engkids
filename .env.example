# ============================================
# COMIC LINGUA KIDS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ============================================
# SUPABASE (Database)
# ============================================
# Get these from: https://supabase.com/dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# IMPORTANT: Service role key is SERVER-SIDE ONLY
# Used for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# BUNNY.NET (Video Streaming)
# ============================================
# Get these from: https://dash.bunny.net -> Stream -> Video Library

# 1. API Key: Account Settings -> API -> Read/Write Key
# IMPORTANT: SERVER-SIDE ONLY - No NEXT_PUBLIC_ prefix!
BUNNY_API_KEY=your_bunny_api_key

# 2. Library ID: Stream -> Video Library -> (see URL or Library ID)
BUNNY_LIBRARY_ID=123456
NEXT_PUBLIC_BUNNY_LIBRARY_ID=123456

# 3. CDN Hostname: Stream -> Video Library -> Pull Zone URL
BUNNY_CDN_HOSTNAME=vz-xxxxx.b-cdn.net
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=vz-xxxxx.b-cdn.net

# 4. CDN Security Key (OPTIONAL - only if Token Authentication is enabled)
# Found in: CDN -> Pull Zone -> Security -> Token Authentication -> Security Key
# Leave blank if not using token authentication
BUNNY_CDN_SECURITY_KEY=your_security_key_if_token_auth_enabled

# ============================================
# JWT SECRET (Required for Admin Auth)
# ============================================
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this secret and never expose!
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars

# ============================================
# OPTIONAL: Cloudflare Workers AI
# ============================================
# For AI-powered features (translation, etc.)
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_WORKERS_AI_TOKEN=your_token

# ============================================
# SECURITY (Added for hardened deployment)
# ============================================

# Webhook secret for verifying Bunny.net webhook signatures (HMAC-SHA256)
# Set this to match the secret configured in your Bunny.net webhook settings
BUNNY_WEBHOOK_SECRET=your_bunny_webhook_secret

# Token required for creating the first admin user
# Generate with: openssl rand -base64 32
# Must be provided in the request body when creating the first admin
ADMIN_SETUP_TOKEN=your_admin_setup_token

# Comma-separated list of admin email addresses
# Users with these emails will have admin access via Supabase auth
ADMIN_EMAILS=admin@comiclingua.com

# Comma-separated list of allowed CORS origins
# Default: http://localhost:3000 (dev only)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
