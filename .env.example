# ============================================
# COMIC LINGUA KIDS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ============================================
# SUPABASE (Database)
# ============================================
# Get these from: https://supabase.com/dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# IMPORTANT: Service role key is SERVER-SIDE ONLY
# Used for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# DIGITALOCEAN SPACES (Video storage + CDN playback)
# ============================================
# Create a Space at: https://cloud.digitalocean.com/spaces
# Generate Spaces access keys at: API -> Spaces Keys
# IMPORTANT: The KEY and SECRET are SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix!)

# Region slug of your Space (e.g. sgp1, nyc3, fra1)
DO_SPACES_REGION=sgp1

# S3-compatible origin endpoint for the region (no bucket name in the host)
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# The name of your Space (bucket)
DO_SPACES_BUCKET=engkids-videos

# Public CDN base URL used for playback. Enable the CDN on your Space, then use
# the "Edge" endpoint. Example: https://engkids-videos.sgp1.cdn.digitaloceanspaces.com
# If omitted, the bucket origin URL is used instead.
DO_SPACES_CDN_ENDPOINT=https://engkids-videos.sgp1.cdn.digitaloceanspaces.com

# Spaces access key + secret (SERVER-SIDE ONLY)
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key

# ============================================
# JWT SECRET (Required for Admin Auth)
# ============================================
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this secret and never expose!
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars

# ============================================
# OPTIONAL: Cloudflare Workers AI
# ============================================
# For AI-powered features (translation, etc.)
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_WORKERS_AI_TOKEN=your_token

# ============================================
# SECURITY (Added for hardened deployment)
# ============================================

# Token required for creating the first admin user
# Generate with: openssl rand -base64 32
# Must be provided in the request body when creating the first admin
ADMIN_SETUP_TOKEN=your_admin_setup_token

# Comma-separated list of admin email addresses
# Users with these emails will have admin access via Supabase auth
ADMIN_EMAILS=admin@comiclingua.com

# Admin account used by the create-admin.js setup script (node create-admin.js)
# Change the password here instead of editing the code.
ADMIN_EMAIL=admin@comiclingua.com
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_NAME=Super Admin

# Comma-separated list of allowed CORS origins
# Default: http://localhost:3000 (dev only)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
